# LangGraph AI Assistant - Environment Configuration

# ── API Keys ─────────────────────────────────────────────────────────────
# Required: Mistral API Key for ChatMistralAI agent model
MISTRAL_API_KEY=your_mistral_api_key_here

# Required: Google API Key for GoogleGenerativeAIEmbeddings (gemini-embedding-001)
GOOGLE_API_KEY=your_google_api_key_here

# ── Server Configuration ──────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Database & Paths ──────────────────────────────────────────────────────
# SQLite checkpointer path
DATABASE_PATH=data/chatbot.db

# Chroma Vector Database path for RAG
CHROMA_DB_PATH=data/chroma_database

# Research paper path for RAG tool
PDF_PATH=data/yolo_melanoma_final.pdf

# Short term memory token budget
MAX_TOKEN_BUDGET=1000
